---
import BookingFlow from "../organisms/BookingFlow";

interface Props {
  initialTourId?: string;
}

const { initialTourId } = Astro.props;
---

<main class="min-h-screen flex items-center justify-center">
    <div class="flex flex-col lg:flex-row gap-6 w-full max-w-6xl mx-auto items-stretch justify-center lg:p-8">
        <BookingFlow client:load initialTourId={initialTourId} />
    </div>
</main>
